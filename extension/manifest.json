{
  "manifest_version": 3,
  "name": "Rezka Sync",
  "version": "1.0.0",
  "description": "Синхронизированный просмотр видео на rezka-ua.tv",
  "permissions": [
    "storage",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://rezka-ua.tv/*",
    "https://*.rezka-ua.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rezka Sync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://rezka-ua.tv/*",
        "https://*.rezka-ua.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
