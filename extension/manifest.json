{
  "manifest_version": 3,
  "name": "Watch Together",
  "version": "1.2.0",
  "description": "Watch videos together in sync on any site — YouTube, HDrezka, Kinopoisk and more",
  "permissions": [
    "storage",
    "tabs",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Watch Together"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
